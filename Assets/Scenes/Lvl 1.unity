  m_Script: {fileID: 11500000, guid: 55f7b12202df74ba8abf2247f8d69001, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    name: Dad
    sentences:
    - "\u201CDid you make the lentils yet?\u201D"
    - "\u201CThat\u2019s a good book you are using. If done correctly you will like
      it. But it won\u2019t be exactly how Rupika-naenda makes it.\u201D"
    - "\u201CFor me it has always been something where I know what it is supposed
      to taste like, but it never tastes the same when I try to make it. Even though
      it is such a basic recipe\u201D"
